{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    // DOM lib gets us URL / URLSearchParams / fetch globals that
    // Node 22 also exposes; TS 6 stopped auto-including these via
    // @types/node so they need to be in lib explicitly. Packages
    // that need Node-only built-ins (node:crypto, Buffer) add
    // @types/node and `types: ["node"]` to their tsconfig.
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true
  }
}
