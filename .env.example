# Copy to .env and adjust for your local dev. Never commit .env.

# --- Postgres / PostGIS ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gratisgis
POSTGRES_USER=gratisgis
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://gratisgis:devpassword@localhost:5432/gratisgis?schema=public

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=gratis-gis
KEYCLOAK_CLIENT_ID_WEB=portal-web
KEYCLOAK_CLIENT_ID_API=portal-api
KEYCLOAK_CLIENT_SECRET_WEB=replace-me

# --- Keycloak admin (portal-api -> /admin/users endpoints) ---
# Requires the confidential 'portal-api-admin' client (pre-defined in
# infra/keycloak/realm-gratis-gis.json) with its service-account granted
# the realm-management 'manage-users' role. After first realm import,
# set the client secret in the Keycloak admin console and paste it here.
KEYCLOAK_ADMIN_CLIENT_ID=portal-api-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=replace-me

# --- MinIO ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=gratisgis
MINIO_SECRET_KEY=devpassword
MINIO_BUCKET=gratisgis

# --- Services ---
PORTAL_API_URL=http://localhost:4000
PORTAL_WEB_URL=http://localhost:3000

# --- portal-web ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-string

# --- Backup + restore (admin-only feature; see /admin/backup) ---
# Where backup archives land. Relative paths resolve against the API's
# cwd (monorepo root in dev). In production, point this at an on-host
# volume outside the container filesystem.
BACKUP_DIR=./backups
# Cron expression for the scheduled run. Default is 2am daily.
BACKUP_SCHEDULE_CRON=0 2 * * *
# Set to true to skip scheduled runs while keeping manual "Run now"
# working — useful when debugging an intermittent failure.
# BACKUP_SCHEDULE_DISABLED=false
# How many successful backups to retain. Failed runs are not counted
# against this cap so you can see a streak of failures.
BACKUP_RETENTION_COUNT=7
# If set, pg_dump runs via `docker exec <container> pg_dump` instead
# of shelling out to a host binary. Useful when the API process
# doesn't have pg_dump on PATH (the common Windows dev scenario).
# BACKUP_PGDUMP_DOCKER_CONTAINER=gratis-gis-postgres
