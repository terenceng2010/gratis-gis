# Caddy config for the gratisgis.org production stack. Two virtual
# hosts:
#
#   - {$PORTAL_DOMAIN}      -> portal-web:3000
#                              The Next.js app proxies its own /api/*
#                              calls to portal-api server-side, so
#                              there's no need to route /api/* through
#                              Caddy separately. Browser-side requests
#                              also hit /api/* paths under the same
#                              hostname, which Next.js forwards via
#                              its server actions / route handlers.
#                              ...except: NestJS sets a global /api
#                              prefix and lives on its own port, so
#                              we also route /api/* to portal-api:4000
#                              directly. portal-web does NOT proxy
#                              browser-side calls.
#   - {$AUTH_DOMAIN}        -> keycloak:8080
#                              Keycloak handles its own routing under
#                              /realms, /admin, /resources, etc.
#
# Both hosts get automatic Let's Encrypt certs. The {$ACME_EMAIL}
# placeholder lets Let's Encrypt notify us about renewal failures.
#
# Caddy auto-redirects HTTP to HTTPS by default, so port 80 traffic
# transparently upgrades.

{
    email {$ACME_EMAIL}
    # Production cert authority. Switch to `acme_ca https://acme-staging-v02.api.letsencrypt.org/directory`
    # when iterating on cert issuance to avoid the LE rate limit.
    # No `auto_https off`; we want the default behaviour.
}

# www.gratisgis.org always 301s to the apex. Most users don't type
# www. anymore, but anyone who does shouldn't get an empty/bare
# response or a cert mismatch. Listing the hostname here makes
# Caddy include it in the SAN when it asks Let's Encrypt for a
# cert, so https://www.gratisgis.org also serves valid TLS.
www.{$PORTAL_DOMAIN} {
    redir https://{$PORTAL_DOMAIN}{uri} 301
}

{$PORTAL_DOMAIN} {
    encode gzip zstd

    # Lift the request-body cap so large spatial-data uploads
    # (county-scale parcel layers run 200-500 MB zipped) stream
    # through Caddy. Caddy 2 default is unlimited but some deploy
    # paths set a lower cap; explicit max_size makes the intent
    # obvious. Multer at the api caps at 1 GB; this matches.
    request_body {
        max_size 1GB
    }

    # Send everything to the web app. Next.js's standalone server is
    # http only and listens on port 3000. The api routes (/api/*)
    # are NestJS, listening separately on portal-api:4000 with its
    # own /api global prefix -- EXCEPT a few prefixes owned by the
    # web container:
    #
    #   /api/auth/*    NextAuth: signin / callback / error / signout
    #   /api/portal/*  BFF passthrough; injects the Keycloak access
    #                  token server-side and forwards to portal-api,
    #                  so the browser never holds the JWT.
    #   /api/geocode/* server-side geocoding helper.
    #
    # Caddy evaluates handle blocks in order, so the more specific
    # web-owned prefixes have to come before the catch-all
    # /api/* -> portal-api block.
    handle /api/auth/* {
        reverse_proxy portal-web:3000
    }
    handle /api/portal/* {
        reverse_proxy portal-web:3000
    }
    handle /api/geocode/* {
        reverse_proxy portal-web:3000
    }
    # portal-api runs as N replicas (deploy.replicas in
    # docker-compose.prod.yml). `dynamic a` re-resolves the DNS A
    # record every 30s and round-robins across every IP that comes
    # back, so adding/removing replicas takes effect within the
    # refresh window without a Caddy restart. With a static
    # `reverse_proxy portal-api:4000`, Caddy resolves once at startup
    # and pins to whichever replica it saw first; this avoided that.
    handle /api/* {
        reverse_proxy {
            dynamic a {
                name portal-api
                port 4000
                refresh 30s
            }
            lb_policy round_robin
        }
    }
    handle /docs {
        reverse_proxy {
            dynamic a {
                name portal-api
                port 4000
                refresh 30s
            }
            lb_policy round_robin
        }
    }
    handle /docs/* {
        reverse_proxy {
            dynamic a {
                name portal-api
                port 4000
                refresh 30s
            }
            lb_policy round_robin
        }
    }
    handle /health {
        reverse_proxy {
            dynamic a {
                name portal-api
                port 4000
                refresh 30s
            }
            lb_policy round_robin
        }
    }

    # Everything else: the Next.js portal.
    handle {
        reverse_proxy portal-web:3000
    }

    # Cache static assets aggressively. Next emits filename-hashed
    # bundles under /_next/static so a year is safe.
    @nextStatic path /_next/static/*
    header @nextStatic Cache-Control "public, max-age=31536000, immutable"

    # Light security headers. CSP is intentionally absent; Next + Map
    # tile loads make a strict CSP a separate project.
    #
    # HSTS: Caddy does NOT automatically add Strict-Transport-Security
    # in v2 despite a stale community-help thread that says it does;
    # I checked the live response headers and it was absent.  Set it
    # explicitly here with a long max-age + includeSubDomains so
    # auth., storage., and www. inherit pinning, and `preload` so we
    # can submit to hstspreload.org once the cert and DNS posture has
    # been stable long enough.
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        # Permissions-Policy: deny access to APIs the portal doesn't
        # use.  Geolocation is left "self" because the field PWA's
        # map widget needs it.  Camera + microphone aren't used today;
        # if we add in-app capture later they'll need to be added back.
        Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=(), usb=(), midi=(), magnetometer=(), accelerometer=(), gyroscope=()"
        # Open same-origin-only window cross-references so popups
        # opened from the portal don't share a browsing context with
        # the opener.  Useful when a Map embeds an external service
        # in an iframe and that service tries to call window.opener.
        Cross-Origin-Opener-Policy same-origin
        -Server
    }
}

{$AUTH_DOMAIN} {
    encode gzip zstd

    # Lock the Keycloak admin surface to the LAN / SSH-tunnel side.
    # Three groups of paths are blocked at the edge:
    #
    # 1. Master-realm admin console + interactive login surfaces.
    #    The master realm has root admin rights over every other
    #    realm on this server.
    # 2. The whole Admin REST API at /admin/realms/* and related
    #    introspection endpoints (/admin/serverinfo, /metrics).
    #    portal-api speaks to Keycloak over the docker network as
    #    keycloak:8080, so nothing the application needs goes
    #    through Caddy to /admin/*.
    # 3. The master-realm interactive login flow.  Our own scripts
    #    (seed-test-users.sh, the email-lock helper) keep working
    #    because they POST to /realms/master/protocol/openid-connect/token,
    #    which is deliberately left through.
    #
    # The gratis-gis realm stays fully reachable for end-user auth
    # via /realms/gratis-gis/*.
    #
    # If you ever need the admin console / Admin REST surface while
    # these blocks are live, reach Keycloak directly:
    #   ssh -L 8081:localhost:8081 gratis  # forward the host port
    #   open http://localhost:8081/admin/  # or run kcadm.sh inside the container
    @adminApi path /admin /admin/* /metrics
    @masterLoginUi path /realms/master/account /realms/master/account/* \
                        /realms/master/login-actions /realms/master/login-actions/* \
                        /realms/master/protocol/openid-connect/auth \
                        /realms/master/protocol/openid-connect/registrations \
                        /realms/master/.well-known/openid-configuration
    handle @adminApi {
        respond 404
    }
    handle @masterLoginUi {
        respond 404
    }

    reverse_proxy keycloak:8080 {
        # Keycloak (with --proxy-headers=xforwarded) trusts the
        # X-Forwarded-* headers Caddy sets by default, so no extra
        # config is needed here.
    }

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        # Don't set X-Frame-Options DENY on auth: the login screen
        # is sometimes embedded in an iframe during account-linking
        # flows. Keycloak sets its own conservative defaults.
    }
}

# Public-facing MinIO. The browser hits presigned PUTs and public
# GETs (item thumbnails, hero images, feature attachments) directly
# at this host. Signature v4 covers the Host header, so the api has
# to mint URLs that target THIS hostname (MINIO_ENDPOINT below) and
# Caddy has to preserve the Host on the way through. Caddy v2's
# reverse_proxy preserves Host by default, which is what we need.
{$STORAGE_DOMAIN} {
    encode gzip zstd

    # MinIO speaks plain HTTP inside the docker network. The TLS
    # termination is here at Caddy.
    reverse_proxy minio:9000

    header {
        X-Content-Type-Options nosniff
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        # No X-Frame-Options or strict referrer policy here: MinIO
        # serves binary blobs that get embedded in <img> tags from the
        # portal, and overly strict headers can break that. The bucket
        # policy is what gates which objects are publicly readable.
        # Mask the upstream server identity (-Server strips MinIO's
        # "Server: MinIO" header on the way out).
        -Server
    }
}
