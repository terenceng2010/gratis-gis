# Production environment for the gratisgis.org stack. Copy this file
# to `infra/.env.prod` on the deploy host and fill in real values.
# Never commit `.env.prod` itself; it's gitignored.
#
# Generate strong values for any line that says "GENERATE":
#   openssl rand -base64 36
#
# Once values are set, deploy with:
#   docker compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod up -d --build

# --- Public hostnames ---
PORTAL_DOMAIN=gratisgis.org
AUTH_DOMAIN=auth.gratisgis.org
PUBLIC_URL=https://gratisgis.org

# --- Let's Encrypt ---
# Email Let's Encrypt notifies if cert renewal fails. Use a real
# inbox you check.
ACME_EMAIL=matthew.palavido@gmail.com

# --- Postgres (app DB) ---
POSTGRES_DB=gratisgis
POSTGRES_USER=gratisgis
POSTGRES_PASSWORD=GENERATE
# Separate password for the keycloak role + database created in
# init-prod-db.sh. Different from POSTGRES_PASSWORD on purpose so a
# leak of one doesn't compromise both.
KEYCLOAK_DB_PASSWORD=GENERATE

# --- MinIO (object storage) ---
MINIO_ROOT_USER=gratisgis
MINIO_ROOT_PASSWORD=GENERATE
S3_BUCKET=gratisgis

# --- Keycloak ---
KEYCLOAK_REALM=gratis-gis
KEYCLOAK_HOSTNAME=auth.gratisgis.org
KEYCLOAK_ISSUER=https://auth.gratisgis.org/realms/gratis-gis
KEYCLOAK_ADMIN=admin
# Initial bootstrap admin password. You log into the Keycloak admin
# console at https://auth.gratisgis.org/admin/ with this; create real
# users from there.
KEYCLOAK_ADMIN_PASSWORD=GENERATE

# portal-web is a public client (PKCE auth code flow) so its
# "secret" is the empty string. The variable still has to be
# present for NextAuth's KeycloakProvider to register at boot.
KEYCLOAK_CLIENT_ID=portal-web
KEYCLOAK_CLIENT_SECRET=

# portal-api-admin is a CONFIDENTIAL service-account client used by
# the api for user-reconcile / role mutation. The realm-import
# substitutes this secret into the realm JSON, and the api reads it
# from this env var to authenticate against Keycloak's admin REST.
KEYCLOAK_ADMIN_CLIENT_ID=portal-api-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=GENERATE

# Initial admin user seeded into the realm. The temporary flag is on
# so Keycloak forces a password change on first login.
INITIAL_USER_PASSWORD=GENERATE

# Default org slug seeded onto the initial admin user (org claim in
# the JWT). The api creates the org row from this slug on first auth.
DEFAULT_ORG_SLUG=gratis-gis

# --- NextAuth ---
# JWT signing key for NextAuth's own session tokens (separate from
# the Keycloak access tokens). 32+ bytes of random.
NEXTAUTH_SECRET=GENERATE

# --- Optional: organization branding ---
# Default org name for the seeded organization. Editable later via
# /admin/general; this just controls the initial value.
DEFAULT_ORG_NAME=GratisGIS
