{
  "realm": "gratis-gis",
  "enabled": true,
  "displayName": "Portal",
  "displayNameHtml": "<span>Portal</span>",
  "loginTheme": "portal",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "NONE",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "attributes": {
    "frontendUrl": "http://localhost:8080"
  },
  "clients": [
    {
      "clientId": "portal-web",
      "name": "GratisGIS Portal Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "org",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org",
            "jsonType.label": "String"
          }
        },
        {
          "name": "org_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org_role",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org_role",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "portal-api",
      "name": "GratisGIS Portal API",
      "enabled": true,
      "bearerOnly": true
    },
    {
      "clientId": "portal-api-admin",
      "name": "GratisGIS Portal API (admin)",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "replace-me-after-realm-import",
      "attributes": {
        "use.refresh.tokens": "false"
      }
    },
    {
      "clientId": "field-app",
      "name": "GratisGIS Field App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "gratisgis://auth-callback",
        "http://localhost:19000/*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "org",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org",
            "jsonType.label": "String"
          }
        },
        {
          "name": "org_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org_role",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org_role",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "Can view shared items"
      },
      {
        "name": "contributor",
        "description": "Can create and share items"
      },
      {
        "name": "admin",
        "description": "Organization administrator"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@acme.test",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ],
      "attributes": {
        "org": [
          "acme"
        ],
        "org_role": [
          "admin"
        ]
      }
    },
    {
      "username": "contributor",
      "email": "contributor@acme.test",
      "firstName": "Contributor",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "contributor",
          "temporary": false
        }
      ],
      "realmRoles": [
        "contributor"
      ],
      "attributes": {
        "org": [
          "acme"
        ],
        "org_role": [
          "contributor"
        ]
      }
    },
    {
      "username": "viewer",
      "email": "viewer@acme.test",
      "firstName": "Viewer",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer"
      ],
      "attributes": {
        "org": [
          "acme"
        ],
        "org_role": [
          "viewer"
        ]
      }
    },
    {
      "username": "service-account-portal-api-admin",
      "enabled": true,
      "serviceAccountClientId": "portal-api-admin",
      "clientRoles": {
        "realm-management": [
          "manage-users"
        ]
      }
    }
  ]
}
