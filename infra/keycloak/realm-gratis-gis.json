{
  "realm": "gratis-gis",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "attributes": {
    "frontendUrl": "http://localhost:8080"
  },
  "clients": [
    {
      "clientId": "portal-web",
      "name": "GratisGIS Portal Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "org",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org",
            "jsonType.label": "String"
          }
        },
        {
          "name": "org_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org_role",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org_role",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "portal-api",
      "name": "GratisGIS Portal API",
      "enabled": true,
      "bearerOnly": true
    },
    {
      "_comment": "Confidential service-account client used by portal-api to call the Keycloak Admin REST API (list/create/update/delete users under /admin/users). Requires the realm-management 'manage-users' role on its service account. Secret is set per-environment via Keycloak admin console or KEYCLOAK_ADMIN_CLIENT_SECRET at import time.",
      "clientId": "portal-api-admin",
      "name": "GratisGIS Portal API (admin)",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "replace-me-after-realm-import",
      "attributes": {
        "use.refresh.tokens": "false"
      }
    },
    {
      "clientId": "field-app",
      "name": "GratisGIS Field App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "gratisgis://auth-callback",
        "http://localhost:19000/*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "org",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org",
            "jsonType.label": "String"
          }
        },
        {
          "name": "org_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org_role",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org_role",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "viewer", "description": "Can view shared items" },
      { "name": "publisher", "description": "Can create and share items" },
      { "name": "admin", "description": "Organization administrator" }
    ]
  },
  "users": [
    {
      "username": "mateo",
      "email": "mateo@acme.test",
      "firstName": "Mateo",
      "lastName": "García",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpassword", "temporary": false }],
      "realmRoles": ["publisher"],
      "attributes": {
        "org": ["acme"],
        "org_role": ["publisher"]
      }
    },
    {
      "username": "bob",
      "email": "bob@acme.test",
      "firstName": "Bob",
      "lastName": "Example",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpassword", "temporary": false }],
      "realmRoles": ["admin"],
      "attributes": {
        "org": ["acme"],
        "org_role": ["admin"]
      }
    }
  ]
}
