{
  "realm": "gratis-gis",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "attributes": {
    "frontendUrl": "http://localhost:8080"
  },
  "clients": [
    {
      "clientId": "portal-web",
      "name": "GratisGIS Portal Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "portal-api",
      "name": "GratisGIS Portal API",
      "enabled": true,
      "bearerOnly": true
    },
    {
      "clientId": "field-app",
      "name": "GratisGIS Field App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "gratisgis://auth-callback",
        "http://localhost:19000/*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "roles": {
    "realm": [
      { "name": "viewer", "description": "Can view shared items" },
      { "name": "publisher", "description": "Can create and share items" },
      { "name": "admin", "description": "Organization administrator" }
    ]
  },
  "users": [
    {
      "username": "alice",
      "email": "alice@acme.test",
      "firstName": "Alice",
      "lastName": "Example",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpassword", "temporary": false }],
      "realmRoles": ["publisher"],
      "attributes": {
        "org": ["acme"],
        "org_role": ["publisher"]
      }
    },
    {
      "username": "bob",
      "email": "bob@acme.test",
      "firstName": "Bob",
      "lastName": "Example",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpassword", "temporary": false }],
      "realmRoles": ["admin"],
      "attributes": {
        "org": ["acme"],
        "org_role": ["admin"]
      }
    }
  ]
}
