# docker compose picks up env vars from the same-dir .env. Copy this
# file to `.env` (same directory as docker-compose.yml) and edit to
# match your dev box. Everything here is optional — unset falls back
# to the planet defaults in docker-compose.yml, which only make sense
# on a production-grade host.

# --- Nominatim (geocoder) ---

# Choose your OSM extract. Geofabrik publishes extracts at every
# level from full planet down to individual US counties:
#   https://download.geofabrik.de/
#
# North America (~13 GB PBF, ~12 hr import on SSD, ~350 GB imported DB):
NOMINATIM_PBF_URL=https://download.geofabrik.de/north-america-latest.osm.pbf
NOMINATIM_REPLICATION_URL=https://download.geofabrik.de/north-america-updates/

# Wikipedia ranking data adds ~20 GB to the import and substantially
# improves result quality for ambiguous place names. Turn it off for
# fast iteration; turn it on before going to prod.
NOMINATIM_IMPORT_WIKIPEDIA=false

# Size the Postgres shared-memory segment to the import you're doing.
# 8 GB is the floor for North America; bump to 16+ for planet.
NOMINATIM_SHM_SIZE=8gb

# Leave FREEZE=true for a geocoder-only deployment (cuts ~30% of the
# footprint). Turn off if you plan to reimport or apply diffs.
NOMINATIM_FREEZE=true

# Match your available cores. 8 is a good middle.
NOMINATIM_THREADS=8
