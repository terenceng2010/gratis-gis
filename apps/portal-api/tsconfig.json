{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "jest"],
    // Emit even if the type-checker produces warnings. nest-cli sets this
    // to true by default, which silently skips producing dist/ files when
    // there are any errors at all. We handle type errors separately via
    // the `typecheck` script; the build step should always emit.
    "noEmitOnError": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
