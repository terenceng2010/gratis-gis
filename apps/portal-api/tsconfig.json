{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    // TS 6 renamed "Node" to "node10" and deprecated the old alias
    // (per https://aka.ms/ts6). Keeping the classic resolver because
    // Nest emits CJS and the runtime imports use the node10 lookup
    // tree; cutting over to "nodenext" is a separate migration.
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "jest", "multer"],
    // Emit even if the type-checker produces warnings. nest-cli sets this
    // to true by default, which silently skips producing dist/ files when
    // there are any errors at all. We handle type errors separately via
    // the `typecheck` script; the build step should always emit.
    "noEmitOnError": false,
    // Incremental builds share a .tsbuildinfo cache. When the cache gets
    // poisoned (e.g. by a mid-build crash or a deleted dist/) tsc will
    // silently skip emit on subsequent runs, producing nothing and no
    // error. Turn it off for portal-api; the watch workflow uses
    // `node --watch` for fast reloads anyway.
    "incremental": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
