// Prisma schema for GratisGIS portal-api.
// See /docs/data-model.md for the design rationale.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuidOssp(map: "uuid-ossp"), pgcrypto, pg_trgm]
}

// ---------- Enums ----------

enum OrgRole {
  viewer
  publisher
  admin
}

enum GroupAccess {
  private
  org
  public
}

enum GroupRole {
  member
  admin
}

enum ItemAccess {
  private
  org
  public
}

enum SharePermission {
  view
  edit
  admin
}

enum PrincipalType {
  user
  group
}

enum BasemapSourceKind {
  xyz
  vector_style       @map("vector-style")
  wms
}

enum ItemType {
  web_map                    @map("web-map")
  feature_service            @map("feature-service")
  arcgis_service             @map("arcgis-service")
  form
  form_submission_collection @map("form-submission-collection")
  web_app                    @map("web-app")
  report_template            @map("report-template")
  dashboard
  file
  layer_package              @map("layer-package")
  notebook
  tool
  widget_package             @map("widget-package")
  pick_list                  @map("pick-list")
  geo_boundary               @map("geo-boundary")
}

// ---------- Tables ----------

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  /// Landing-page customization for unauthenticated visitors.
  /// All optional — defaults render a clean page using `name` as the
  /// title and showing publicly-shared items. An org that wants a
  /// minimal logo-only page turns off landingShowPublicItems and
  /// leaves the rest empty.
  landingTitle           String?  @map("landing_title")
  landingSubtitle        String?  @map("landing_subtitle")
  landingHeroImageUrl    String?  @map("landing_hero_image_url")
  landingShowPublicItems Boolean  @default(true) @map("landing_show_public_items")
  /// Ordered list of item ids to feature on the landing. Empty /
  /// null renders all public items in the org, newest-first.
  landingFeaturedItemIds String[] @default([]) @map("landing_featured_item_ids") @db.Uuid

  users    User[]
  groups   Group[]
  items    Item[]
  basemaps Basemap[]

  @@map("organization")
}

model User {
  id        String   @id @db.Uuid // matches Keycloak sub
  orgId     String   @map("org_id") @db.Uuid
  username  String   @unique
  email     String
  fullName  String   @map("full_name")
  orgRole   OrgRole  @default(viewer) @map("org_role")
  /// Absolute URL to the user's avatar image (served from MinIO).
  /// Null falls back to the auto-generated initial badge.
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedGroups   Group[]       @relation("GroupOwner")
  groupMembers  GroupMember[]
  ownedItems    Item[]        @relation("ItemOwner")

  @@index([orgId])
  @@map("user")
}

model Group {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  title        String
  description  String      @default("")
  access       GroupAccess @default(private)
  ownerId      String      @map("owner_id") @db.Uuid
  /// Absolute URL to the group's thumbnail image. Null falls back to
  /// the auto-generated initial badge.
  thumbnailUrl String?     @map("thumbnail_url")
  createdAt    DateTime    @default(now()) @map("created_at")
  // Soft-delete. When set, the group is in the trash and filtered out of
  // normal queries. A scheduled job permanently removes rows whose
  // deletedAt is older than the retention window (see docs/soft-delete.md).
  deletedAt   DateTime?   @map("deleted_at")

  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner      User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members    GroupMember[]

  @@index([orgId])
  @@index([deletedAt])
  @@map("group")
}

model GroupMember {
  groupId  String    @map("group_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  role     GroupRole @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_member")
}

model Item {
  id           String     @id @default(uuid()) @db.Uuid
  orgId        String     @map("org_id") @db.Uuid
  ownerId      String     @map("owner_id") @db.Uuid
  type         ItemType
  title        String
  description  String     @default("")
  tags         String[]   @default([])
  thumbnailUrl String?    @map("thumbnail_url")
  /// Type-specific content payload. The underlying column is
  /// `data_json` so existing migrations are undisturbed; exposing the
  /// TS property as `data` keeps the API response shape aligned with
  /// the client-side `Item` type in shared-types.
  data         Json       @map("data_json")
  storageRef   String?    @map("storage_ref")
  access       ItemAccess @default(private)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  // Soft-delete. See Group.deletedAt for rationale.
  deletedAt    DateTime?  @map("deleted_at")

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner       User                @relation("ItemOwner", fields: [ownerId], references: [id])
  shares      ItemShare[]
  attachments FeatureAttachment[]
  snapshots   ItemDataSnapshot[]

  @@index([orgId, access])
  @@index([ownerId])
  @@index([type])
  @@index([deletedAt])
  @@map("item")
}

/// A share row grants access to an item for a single principal (either a
/// user or a group). We use (principalType, principalId) rather than two
/// nullable FK columns so the composite primary key is always valid.
/// Enforcement that the principalId actually references the correct table
/// is handled by a CHECK constraint + trigger in an SQL migration.
/// Point-in-time snapshot of an Item's `data` blob. Written every
/// time someone replaces the data (upload / paste / bulk import) so
/// an admin can revert to a prior state if the new data was wrong
/// or corrupt. Retention is configurable but defaults to 30 days
/// AND the latest 20 per item, whichever is stricter; older rows
/// are auto-purged by MaintenanceModule.
model ItemDataSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  /// The pre-replace data blob. Full copy, not a diff — simpler
  /// revert + forward-compatible as the item data shape evolves.
  data      Json
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  /// User who caused the snapshot (by replacing the data).
  createdBy String   @map("created_by") @db.Uuid

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
  @@map("item_data_snapshot")
}

/// One row per backup attempt. Recorded whether the run succeeded
/// or failed so operators can see history at a glance. Intentionally
/// NOT scoped by org — backup is infrastructure-level. The target
/// file path is relative to BACKUP_DIR so backups stay portable if
/// the deployment moves to a different host.
enum BackupStatus {
  running
  succeeded
  failed
}

/// Singleton row holding admin-editable backup settings. Env vars
/// (BACKUP_DIR, BACKUP_SCHEDULE_CRON, BACKUP_RETENTION_COUNT) stay
/// as the defaults on first boot; once an admin saves the config
/// form the DB row wins.
///
/// Schedule is stored in structured form (mode + time + day) rather
/// than as a raw cron expression so the UI can render "Weekly on
/// Monday at 02:00" without having to parse cron. A 'custom' mode
/// keeps `customCron` as an escape hatch for operators who want an
/// expression our presets don't cover.
model BackupConfig {
  id String @id @default(uuid()) @db.Uuid

  /// Where archives land. Absolute path; null = fall back to env.
  archiveDirectory String? @map("archive_directory")

  /// 'off' | 'daily' | 'weekly' | 'monthly' | 'custom'
  scheduleMode String @default("daily") @map("schedule_mode")

  /// Time of day in the API host's local timezone. 0-23 / 0-59.
  scheduleHour   Int @default(2) @map("schedule_hour")
  scheduleMinute Int @default(0) @map("schedule_minute")

  /// 0 (Sunday) through 6 (Saturday); used when mode=weekly.
  scheduleDayOfWeek Int? @map("schedule_day_of_week")

  /// 1 through 28; capped at 28 so the cron never silently skips
  /// months (31st → no-op in February).
  scheduleDayOfMonth Int? @map("schedule_day_of_month")

  /// Raw cron expression used when scheduleMode === 'custom'.
  customCron String? @map("custom_cron")

  /// How many successful backups to keep. Null = fall back to env.
  retentionCount Int? @map("retention_count")

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("backup_config")
}

/// History of backup-restore operations. Rows survive the restore
/// they describe because pg_dump writes this table as-of "just
/// before the restore started", but we intentionally INSERT the
/// success row AFTER the new data is in — see BackupRestoreService.
/// Destructive by definition, so the audit record is the only
/// trail left of a run that overwrote everything else.
enum RestoreStatus {
  running
  succeeded
  failed
}

model BackupRestore {
  id         String        @id @default(uuid()) @db.Uuid
  /// Source run the archive came from. May be null if the admin
  /// restored from an uploaded archive not tied to a prior run
  /// (reserved for Phase 2 upload-flow; Phase 1 always references
  /// an existing BackupRun).
  fromRunId  String?       @map("from_run_id") @db.Uuid
  filename   String
  startedAt  DateTime      @default(now()) @map("started_at")
  finishedAt DateTime?     @map("finished_at")
  status     RestoreStatus @default(running)
  /// Keycloak user id of the admin who initiated the restore.
  startedBy  String        @map("started_by") @db.Uuid
  /// Short error summary. Full trace is in the server log.
  error      String?

  @@index([startedAt])
  @@map("backup_restore")
}

model BackupRun {
  id         String       @id @default(uuid()) @db.Uuid
  startedAt  DateTime     @default(now()) @map("started_at")
  finishedAt DateTime?    @map("finished_at")
  status     BackupStatus @default(running)

  /// Filename (NOT full path) relative to BACKUP_DIR. Null while the
  /// run is in progress; set atomically at finish. Kept opaque so
  /// operators can move the file to cold storage and just update the
  /// row if they need to.
  filename String?
  /// Bytes on disk after compression. Null if the run failed before
  /// the archive was sealed.
  sizeBytes BigInt? @map("size_bytes")

  /// 'manual' or 'scheduled' — lets the UI separate ad-hoc runs from
  /// cron-driven ones, and lets retention treat manual backups more
  /// gently (operators may want a just-ran manual one to survive an
  /// aggressive retention window).
  trigger String @default("manual")

  /// Keycloak user id that kicked off a manual run; null for
  /// scheduled runs.
  startedBy String? @map("started_by") @db.Uuid

  /// Short error summary (first 500 chars). Full stack is in the
  /// server log; here we just want enough for the admin table to
  /// show a tooltip.
  error String?

  @@index([startedAt])
  @@map("backup_run")
}

model ItemShare {
  itemId        String          @map("item_id") @db.Uuid
  principalType PrincipalType   @map("principal_type")
  principalId   String          @map("principal_id") @db.Uuid
  permission    SharePermission @default(view)
  createdAt     DateTime        @default(now()) @map("created_at")

  /// Optional geographic restriction. When set, the principal can
  /// only see features whose geometry intersects this polygon, and
  /// items whose bbox intersects it. Stored as GeoJSON (EPSG:4326)
  /// so the frontend can draw / edit without a coordinate transform.
  /// Null = no geographic restriction (full share grant).
  geoLimit Json? @map("geo_limit")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, principalType, principalId])
  @@index([principalType, principalId])
  @@map("item_share")
}

/// Custom basemap registered by an org admin. Appears in the web map
/// editor's basemap picker alongside the built-in set compiled into
/// portal-web. Each row is a MapLibre source recipe — a raster tile
/// URL (XYZ), a vector style.json URL, or a WMS GetMap endpoint.
///
/// sourceKind tells the renderer which flavor we're dealing with so
/// the picker can build the right MapLibre style on the fly without
/// having to sniff content types at request time.
/// A file attached to a specific feature inside a v3 feature-service
/// layer. The bytes live in MinIO at `storageKey` and are served via
/// the long-lived `storageUrl`. We never embed the bytes here — only
/// metadata + the CDN-style URL the viewer dereferences at render time.
///
/// (itemId, layerId, featureId) form the logical parent tuple; we
/// don't FK on featureId because features live in a dynamically-named
/// PostGIS table per layer (fs_<itemId>_<layerId>), which Prisma can't
/// model directly. Item-level cascade still catches the common case
/// when an item is purged — app-level cleanup handles feature deletes.
model FeatureAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  itemId     String   @map("item_id") @db.Uuid
  /// Layer id as it appears in item.data.layers[].id (sanitized slug,
  /// not a UUID). Kept as TEXT so the v3 id format can grow.
  layerId    String   @map("layer_id")
  /// global_id of the feature inside the layer's PostGIS table.
  featureId  String   @map("feature_id") @db.Uuid
  fileName   String   @map("file_name")
  mime       String
  sizeBytes  Int      @map("size_bytes")
  /// MinIO object key under the configured bucket.
  storageKey String   @map("storage_key")
  /// Stable public URL the viewer can cache/share.
  storageUrl String   @map("storage_url")
  createdAt  DateTime @default(now()) @map("created_at")
  createdBy  String   @map("created_by") @db.Uuid

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, layerId, featureId])
  @@map("feature_attachment")
}

model Basemap {
  id           String            @id @default(uuid()) @db.Uuid
  orgId        String            @map("org_id") @db.Uuid
  /// Human-readable name shown in the picker.
  label        String
  /// Short description shown under the label.
  description  String            @default("")
  /// URL template for xyz (with {z}/{x}/{y}), a full style.json URL
  /// for vector_style, or a WMS GetMap URL for wms.
  url          String
  sourceKind   BasemapSourceKind @map("source_kind")
  /// Attribution text rendered verbatim in the map chrome.
  attribution  String            @default("")
  /// Optional preview image URL; null falls back to a badge tile.
  thumbnailUrl String?           @map("thumbnail_url")
  /// Source-kind-specific extras (e.g. WMS layers, format, CRS).
  /// JSON so we can grow it without a migration per knob.
  config       Json?             @db.JsonB
  /// Exactly one basemap per org may be the default (used for fresh
  /// web maps). Enforced at the service layer; a partial unique
  /// index could also enforce it in a follow-up SQL migration.
  isDefault    Boolean           @default(false) @map("is_default")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt        @map("updated_at")
  createdBy    String            @map("created_by") @db.Uuid

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("basemap")
}
