// Prisma schema for GratisGIS portal-api.
// See /docs/data-model.md for the design rationale.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuidOssp(map: "uuid-ossp"), pgcrypto, pg_trgm]
}

// ---------- Enums ----------

enum OrgRole {
  viewer
  publisher
  admin
}

enum GroupAccess {
  private
  org
  public
}

enum GroupRole {
  member
  admin
}

enum ItemAccess {
  private
  org
  public
}

enum SharePermission {
  view
  edit
  admin
}

enum PrincipalType {
  user
  group
}

enum ItemType {
  web_map                    @map("web-map")
  feature_service            @map("feature-service")
  form
  form_submission_collection @map("form-submission-collection")
  web_app                    @map("web-app")
  report_template            @map("report-template")
  dashboard
  file
  layer_package              @map("layer-package")
  notebook
  tool
  widget_package             @map("widget-package")
}

// ---------- Tables ----------

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  users  User[]
  groups Group[]
  items  Item[]

  @@map("organization")
}

model User {
  id        String   @id @db.Uuid // matches Keycloak sub
  orgId     String   @map("org_id") @db.Uuid
  username  String   @unique
  email     String
  fullName  String   @map("full_name")
  orgRole   OrgRole  @default(viewer) @map("org_role")
  /// Absolute URL to the user's avatar image (served from MinIO).
  /// Null falls back to the auto-generated initial badge.
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedGroups   Group[]       @relation("GroupOwner")
  groupMembers  GroupMember[]
  ownedItems    Item[]        @relation("ItemOwner")

  @@index([orgId])
  @@map("user")
}

model Group {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  title        String
  description  String      @default("")
  access       GroupAccess @default(private)
  ownerId      String      @map("owner_id") @db.Uuid
  /// Absolute URL to the group's thumbnail image. Null falls back to
  /// the auto-generated initial badge.
  thumbnailUrl String?     @map("thumbnail_url")
  createdAt    DateTime    @default(now()) @map("created_at")
  // Soft-delete. When set, the group is in the trash and filtered out of
  // normal queries. A scheduled job permanently removes rows whose
  // deletedAt is older than the retention window (see docs/soft-delete.md).
  deletedAt   DateTime?   @map("deleted_at")

  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner      User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members    GroupMember[]

  @@index([orgId])
  @@index([deletedAt])
  @@map("group")
}

model GroupMember {
  groupId  String    @map("group_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  role     GroupRole @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_member")
}

model Item {
  id           String     @id @default(uuid()) @db.Uuid
  orgId        String     @map("org_id") @db.Uuid
  ownerId      String     @map("owner_id") @db.Uuid
  type         ItemType
  title        String
  description  String     @default("")
  tags         String[]   @default([])
  thumbnailUrl String?    @map("thumbnail_url")
  /// Type-specific content payload. The underlying column is
  /// `data_json` so existing migrations are undisturbed; exposing the
  /// TS property as `data` keeps the API response shape aligned with
  /// the client-side `Item` type in shared-types.
  data         Json       @map("data_json")
  storageRef   String?    @map("storage_ref")
  access       ItemAccess @default(private)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  // Soft-delete. See Group.deletedAt for rationale.
  deletedAt    DateTime?  @map("deleted_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner  User         @relation("ItemOwner", fields: [ownerId], references: [id])
  shares ItemShare[]

  @@index([orgId, access])
  @@index([ownerId])
  @@index([type])
  @@index([deletedAt])
  @@map("item")
}

/// A share row grants access to an item for a single principal (either a
/// user or a group). We use (principalType, principalId) rather than two
/// nullable FK columns so the composite primary key is always valid.
/// Enforcement that the principalId actually references the correct table
/// is handled by a CHECK constraint + trigger in an SQL migration.
model ItemShare {
  itemId        String          @map("item_id") @db.Uuid
  principalType PrincipalType   @map("principal_type")
  principalId   String          @map("principal_id") @db.Uuid
  permission    SharePermission @default(view)
  createdAt     DateTime        @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, principalType, principalId])
  @@index([principalType, principalId])
  @@map("item_share")
}
